# Acumen environment configuration (SPEC §8.3, CODE_SPEC AC-CD16/AC-CD18).
# Copy to `.env` and fill real values. NEVER commit a real `.env`
# (.gitignore excludes it; `.env.example` is whitelisted). No secrets
# in code or in the database — configuration is env-only and loaded at
# container startup.
#
# REQUIRED IN PRODUCTION (boot-enforced): when APP_ENV is NOT one of
# {development, dev, local, test}, the app's startup check
# (app/config.py::check_startup_config, run from the FastAPI lifespan)
# RAISES and refuses to boot if APP_SECRET_KEY or JWT_SECRET is still
# "change-me", or if CORS_ALLOWED_ORIGINS is wildcard/localhost. Missing
# ANTHROPIC_API_KEY / OPENAI_API_KEY logs a loud startup WARNING in every
# env (the provider silently falls back to a stub otherwise). The full
# required-in-prod checklist lives in docs/DEPLOYMENT.md.

# --- APP_* ---
# APP_ENV: set to "production" (or any non-dev value) for real deployments;
# this arms the fail-closed boot checks above.
APP_ENV=development
APP_PUBLIC_URL=http://localhost:8000
# APP_FRONTEND_URL: the externally-visible **frontend** origin (the browser
# app), used to build setup/reset email links (AC-CD5 link contract).
# DISTINCT from APP_PUBLIC_URL (the API origin). REQUIRED in prod — boot
# RAISEs in a non-dev APP_ENV if it is empty/localhost or is NOT one of the
# CORS_ALLOWED_ORIGINS entries below. Default is the Next.js dev server.
APP_FRONTEND_URL=http://localhost:3000
# APP_SECRET_KEY: REQUIRED in prod — must be overridden from "change-me"
# (boot RAISEs otherwise). Generate a long random value.
APP_SECRET_KEY=change-me
APP_FILE_STORAGE_PATH=/var/lib/acumen/files

# --- Database (async runtime + sync migration driver, CODE_SPEC §2) ---
DATABASE_URL=postgresql+asyncpg://acumen:acumen@postgres:5432/acumen
DATABASE_MIGRATION_URL=postgresql+psycopg://acumen:acumen@postgres:5432/acumen
DB_SCHEMA=acumen

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT (AC-D10 / AC-CD5) ---
# JWT_SECRET: REQUIRED in prod — must be overridden from "change-me"
# (boot RAISEs otherwise). Independent of APP_SECRET_KEY; use a distinct
# long random value.
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# --- Anthropic (5 primary ops; model IDs env-overridable, AC-CD18) ---
# ANTHROPIC_API_KEY: unset logs a loud startup WARNING in EVERY env — the
# provider falls back to a stub (not a real model). Set for any deployment
# that must actually call Anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_GENERATION=claude-sonnet-4-6
ANTHROPIC_MODEL_GRADING=claude-sonnet-4-6
ANTHROPIC_MODEL_WEAKNESS=claude-sonnet-4-6
ANTHROPIC_MODEL_MATERIAL=claude-sonnet-4-6
ANTHROPIC_MODEL_PILL_PROPOSAL=claude-sonnet-4-6
ANTHROPIC_MODEL_PILL_GENERATION=claude-sonnet-4-6

# --- OpenAI (cross-family review + embeddings, AC-D19 / AC-D22) ---
# OPENAI_API_KEY: unset logs a loud startup WARNING in EVERY env — the
# cross-family review + embeddings fall back to a stub (not a real model).
OPENAI_API_KEY=
OPENAI_MODEL_REVIEW=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Google Drive RAG (AC-D22) ---
GOOGLE_DRIVE_CREDENTIALS_JSON=
GOOGLE_DRIVE_FOLDER_ID=

# --- Web search (safety-pill link curation, AC-D21) ---
WEB_SEARCH_API_KEY=

# --- Source-authority allowlist (corpus acquisition, AC-D28) ---
# Per-tier comma-separated host patterns appended to the coded seed
# allowlist (exact host or *.suffix wildcard). Operator-curated; widens
# what the autonomous corpus builder may fetch. Empty by default.
SOURCE_AUTHORITY_T1_EXTRA=
SOURCE_AUTHORITY_T2_EXTRA=
SOURCE_AUTHORITY_T3_EXTRA=

# --- SMTP (setup/reset/reminder/escalation, AC-D10 / AC-D26) ---
SMTP_HOST=
SMTP_PORT=587
# Resend SMTP credentials are case-sensitive — keep username as literal lowercase 'resend'.
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=acumen@example.com

# --- JIT streaming buffer (AC-D25); DB-stored per-op knobs land in P1 ---
JIT_BUFFER_SIZE=3
JIT_BUFFER_MAX=5

# --- CORS (frontend origin allowlist, AC-CD19) ---
# Comma-separated list. REQUIRED in prod — must be the real frontend
# origin(s) (e.g. https://acumen.example.com); a wildcard ("*") or any
# localhost/loopback origin makes the startup check RAISE in a non-dev
# APP_ENV (no-wildcard rule). Default is the Next.js dev server at :3000.
CORS_ALLOWED_ORIGINS=http://localhost:3000
