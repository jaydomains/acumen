# Acumen frontend environment configuration (AC-CD19).
# Copy to `.env.local` (gitignored) and fill real values. Two flavours:
#  - NEXT_PUBLIC_*  : injected at build time, shipped to the browser
#  - all others     : server-only, never exposed to the browser

# Backend API base URL as seen from the BROWSER. In local dev this is
# the host-exposed FastAPI port (`docker compose up` maps acumen → :8000).
# In production, this is whatever your reverse proxy exposes.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend API base URL as seen from the Next.js SERVER (RSC / route
# handlers). Inside docker compose this resolves to the `acumen` service
# on its internal port; on a developer's laptop running `pnpm dev`
# outside docker, it's the same as the public URL.
API_BASE_URL=http://localhost:8000

# Mock-Service-Worker dev toggle. Set to `enabled` to run the frontend
# against in-browser MSW handlers (no backend required) — useful for
# building auth flows in isolation. Any other value (or unset) hits the
# real backend at NEXT_PUBLIC_API_BASE_URL.
# NEXT_PUBLIC_API_MOCKING=enabled
