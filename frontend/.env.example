# Acumen frontend environment configuration (AC-CD19).
# Copy to `.env.local` (gitignored) and fill real values. All variables
# below are read at RUNTIME — none are baked into the build, so the
# same Docker image can be deployed against any backend.

# Backend API base URL exposed to the BROWSER. Served to the browser
# at boot via /api/config (Next.js route handler). The browser fetches
# this same-origin on app start; no env is baked into the JS bundle.
# Must match the backend's APP_PUBLIC_URL in production.
API_BASE_URL_PUBLIC=http://localhost:8000

# Backend API base URL as seen from the Next.js SERVER (RSC / route
# handlers). Inside docker compose this resolves to the `acumen`
# service on its internal port; on a developer's laptop running
# `pnpm dev` outside docker, it's the same as the public URL.
API_BASE_URL=http://localhost:8000

# Mock-Service-Worker dev toggle. Set to `enabled` to run the frontend
# against in-browser MSW handlers (no backend required) — useful for
# building auth flows in isolation. When enabled, ConfigProvider skips
# the /api/config fetch and uses the MSW fallback URL.
# NEXT_PUBLIC_API_MOCKING=enabled
