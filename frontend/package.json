{
  "name": "acumen-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "codegen": "openapi-typescript ./openapi/schema.json -o ./src/types/api.d.ts",
    "codegen:live": "openapi-typescript http://localhost:8000/openapi.json -o ./src/types/api.d.ts",
    "codegen:check": "openapi-typescript ./openapi/schema.json -o ./src/types/api.d.ts.tmp && diff -q ./src/types/api.d.ts ./src/types/api.d.ts.tmp && rm ./src/types/api.d.ts.tmp"
  },
  "dependencies": {
    "@tanstack/react-query": "5.62.7",
    "next": "15.1.6",
    "openapi-fetch": "0.17.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "7.54.2",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/react": "16.1.0",
    "@types/node": "22.10.5",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "4.3.4",
    "eslint": "9.18.0",
    "eslint-config-next": "15.1.6",
    "eslint-config-prettier": "9.1.0",
    "jsdom": "25.0.1",
    "openapi-typescript": "7.5.2",
    "prettier": "3.4.2",
    "tailwindcss": "4.3.0",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
